#: pretix_saferpay/__init__.py:10
msgid "Saferpay (SIX)"
msgstr "Saferpay (SIX)"

#: pretix_saferpay/__init__.py:13
msgid ""
"Accept payments through Saferpay, a payment method offered by Worldline "
"(formerly SIX Payment Services)."
msgstr ""
"يمكنك قبول المدفوعات عبر Saferpay، وهي طريقة دفع تقدمها شركة Worldline "
"(المعروفة سابقًا باسم SIX Payment Services)."

