#: pretix_saferpay/templates/pretix_saferpay/checkout_payment_confirm.html:3
#: pretix_saferpay/templates/pretix_saferpay/checkout_payment_form.html:3
msgid ""
"After you submitted your order, we will redirect you to Saferpay to complete "
"your payment. You will then be redirected back here to get your tickets."
msgstr ""
"Après avoir soumis votre commande, nous vous redirigerons vers Saferpay pour "
"finaliser votre paiement. Vous serez ensuite redirigé ici pour obtenir vos "
"billets."

#: pretix_saferpay/templates/pretix_saferpay/checkout_payment_confirm.html:8
#: pretix_saferpay/templates/pretix_saferpay/control.html:15
msgid "Payment method"
msgstr "Mode de paiement"

#: pretix_saferpay/templates/pretix_saferpay/control.html:6
msgid "ID"
msgstr "ID"

#: pretix_saferpay/templates/pretix_saferpay/control.html:8
msgid "Status"
msgstr "Statut"

#: pretix_saferpay/templates/pretix_saferpay/control.html:10
msgid "Date"
msgstr "Date"

#: pretix_saferpay/templates/pretix_saferpay/control.html:12
msgid "SIX Reference"
msgstr "Référence SIX"

#: pretix_saferpay/templates/pretix_saferpay/control.html:17
msgid "Payment source"
msgstr "origine du paiement"

#: pretix_saferpay/templates/pretix_saferpay/control.html:24
msgid "Error message"
msgstr "Message d'erreur"

#: pretix_saferpay/templates/pretix_saferpay/pending.html:4
msgid ""
"We're waiting for an answer from the payment provider regarding your "
"payment. Please contact us if this takes more than a few days."
msgstr ""
"Nous attendons une réponse du fournisseur de paiement concernant votre "
"paiement. Veuillez nous contacter si cela prend plus de quelques jours."

#: pretix_saferpay/templates/pretix_saferpay/pending.html:9
msgid ""
"The payment transaction could not be completed for the following reason:"
msgstr ""
"L’opération de paiement n’a pas pu être effectuée pour la raison suivante :"

#: pretix_saferpay/templates/pretix_saferpay/pending.html:16
msgid "Unknown reason"
msgstr "Raison inconnue"

#: pretix_saferpay/templates/pretix_saferpay/redirect.html:17
msgid "The payment process has started in a new window."
msgstr "Le processus de paiement a commencé dans une nouvelle fenêtre."

#: pretix_saferpay/templates/pretix_saferpay/redirect.html:20
msgid "The window to enter your payment data was not opened or was closed?"
msgstr ""
"La fenêtre de saisie de vos données de paiement n’a pas été ouverte ou a été "
"fermée ?"

#: pretix_saferpay/templates/pretix_saferpay/redirect.html:24
msgid "Click here in order to open the window."
msgstr "Cliquez ici pour ouvrir la fenêtre."

#: pretix_saferpay/views.py:156
msgid ""
"We received your payment but were unable to mark your ticket as the server "
"was too busy. Please check beck in a couple of minutes."
msgstr ""
"Nous avons reçu votre paiement mais n’avons pas pu marquer votre ticket car "
"le serveur était trop occupé. S’il vous plaît vérifier beck dans quelques "
"minutes."

#: pretix_saferpay/views.py:160
msgid ""
"We received your payment but were unable to mark your ticket as paid as one "
"of your ordered products is sold out. Please contact the event organizer for "
"further steps."
msgstr ""
"Nous avons reçu votre paiement, mais nous n’avons pas pu marquer votre "
"billet comme payé car l’un de vos produits commandés est épuisé. Veuillez "
"contacter l’organisateur de l’événement pour plus d’informations."

#: pretix_saferpay/views.py:183
msgid ""
"Sorry, there was an error in the payment process. Please check the link in "
"your emails to continue."
msgstr ""
"Désolé, une erreur s’est produite dans le processus de paiement. Veuillez "
"vérifier le lien dans vos e-mails pour continuer."
